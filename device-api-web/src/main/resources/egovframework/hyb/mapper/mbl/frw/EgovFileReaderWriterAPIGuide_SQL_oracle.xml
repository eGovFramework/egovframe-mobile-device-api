<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="fileReaderWriterAPIDAO">

	<resultMap id="fileReaderWriterInfo" type="egovframework.hyb.mbl.frw.service.FileReaderWriterAPIVO">
		<result property="sn" column="SN"/>
		<result property="uuid" column="UUID"/>
		<result property="useYn" column="USEYN"/>
	</resultMap>

	<insert id="insertFileReaderWriterInfo">
		<selectKey keyProperty="sn" resultType="int" order="BEFORE">
		   SELECT (IFNULL(MAX(SN), 0)+1) sn from FILE_READER_WRITER
		</selectKey>
		
		INSERT INTO FILE_READER_WRITER 
			( SN
			  , UUID
			  , USEYN )
		VALUES ( #{sn}
			  , #{uuid}
			  , #{useYn})
	</insert>
	
	<select id="selectFileReaderWriterInfoList" parameterType="egovframework.hyb.mbl.frw.service.FileReaderWriterAPIVO" resultMap="fileReaderWriterInfo">
		SELECT
			SN, UUID, USEYN
		FROM FILE_READER_WRITER
		WHERE USEYN='Y'
		ORDER BY SN DESC
	</select>

</mapper>
